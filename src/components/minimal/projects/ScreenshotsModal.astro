---
interface ImageMapping {
  file: string;
  label: string;
}

interface Props {
  id: string; // Para el script de JS
  title: string;
  subtitle: string;
  accent: 'amber' | 'blue';
  images: ImageMapping[];
  description: string;
}

const { id, title, subtitle, accent, images, description } = Astro.props;

const headerAccentClass = accent === 'amber' ? 'text-amber-400' : 'text-blue-400';
// Las grillas para 8 o 7 imagenes.
// En Stock (8): cols-2 sm:cols-2 
// En Signo (7, portrait): cols-2 sm:cols-3 lg:cols-4 
const gridClass = accent === 'amber' 
  ? 'grid-cols-2 sm:grid-cols-2' 
  : 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4';
const aspectClass = accent === 'amber' ? 'aspect-video' : 'aspect-[9/16]';
---

<div
  id={`${id}-modal`}
  class="fixed inset-0 z-[300] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
  aria-modal="true"
  role="dialog"
>
  <div class="modal-backdrop absolute inset-0 bg-black/80" id={`${id}-modal-backdrop`}></div>
  <div class="relative z-10 bg-[#111] border border-white/10 w-full max-w-4xl max-h-[85vh] overflow-y-auto mx-4 p-6 md:p-8">
    <div class="flex items-start justify-between mb-8">
      <div>
        <span class={`text-[9px] uppercase tracking-[0.4em] font-mono ${headerAccentClass}`}>{subtitle}</span>
        <h5 class="text-xl font-bold text-white mt-1">{title}</h5>
      </div>
      <button id={`${id}-modal-close`} class="text-neutral-500 hover:text-white transition-colors p-1 -mr-1">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Grilla de imágenes -->
    <div class={`grid gap-3 ${gridClass}`}>
      {images.map(({ file, label }) => (
        <div class="flex flex-col gap-1">
          <div class={`${aspectClass} bg-white/[0.03] border border-white/5 overflow-hidden`}>
            <img src={file} alt={label} class="modal-img object-cover w-full h-full" loading="lazy" />
          </div>
          <span class="text-[9px] font-mono text-neutral-600 uppercase tracking-wider text-center pt-1 leading-tight">{label}</span>
        </div>
      ))}
    </div>

    <p class="text-sm text-neutral-500 mt-6 leading-relaxed border-t border-white/5 pt-6">
      {description}
    </p>
  </div>
</div>
