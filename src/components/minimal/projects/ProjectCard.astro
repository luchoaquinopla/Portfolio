---
import type { CollectionEntry } from 'astro:content';
import { ExternalLink, Github, Database } from '@lucide/astro';

interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
}

const { project, index } = Astro.props;
const { data, id } = project;

const badgeLabel = {
  live: '● Live',
  private: '◆ Privado',
  academic: '▲ Académico',
} as const;

const badgeClasses = {
  live: 'text-emerald-400 border-emerald-400/30 bg-emerald-400/5',
  private: 'text-amber-400 border-amber-400/30 bg-amber-400/5',
  academic: 'text-blue-400 border-blue-400/30 bg-blue-400/5',
} as const;

const numberPrefix = (index + 1).toString().padStart(2, '0');
const hasScreenshots = data.screenshots && data.screenshots.length > 0;
const isAmber = id === 'sistema-stock';
---

<article class="project-entry group relative flex flex-col md:flex-row gap-8 md:gap-16 items-start py-8 md:py-16">
  <!-- Línea conectora -->
  <div class="project-rule absolute top-0 left-0 w-full h-[1px] bg-white/10 group-first:hidden hidden md:block"></div>

  <!-- Número rotado -->
  <div class="hidden md:flex flex-none w-24 pt-4 justify-end">
    <span class="project-number text-7xl font-light text-neutral-800 tracking-tighter -rotate-90 origin-top-right selection:bg-transparent">
      {numberPrefix}
    </span>
  </div>

  <!-- Meta Header Mobile -->
  <div class="flex items-center gap-4 md:hidden w-full mb-2">
    <span class="text-4xl font-light text-neutral-800 tracking-tighter">
      {numberPrefix}
    </span>
    <span class={`px-3 py-1 rounded-full text-[10px] uppercase tracking-[0.2em] font-bold border ${badgeClasses[data.type]}`}>
      {badgeLabel[data.type]}
    </span>
  </div>

  <!-- Contenido -->
  <div class="project-content flex-grow max-w-3xl">
    <div class="flex flex-col gap-6">
      
      <header>
        <div class="hidden md:inline-flex items-center mb-4">
          <span class={`px-3 py-1 rounded-full text-[10px] uppercase tracking-[0.2em] font-bold border ${badgeClasses[data.type]}`}>
            {badgeLabel[data.type]}
          </span>
        </div>
        
        <h3 class="text-4xl md:text-5xl font-bold text-white tracking-tight mb-3">
          {data.name}
        </h3>
        
        <p class="text-[12px] md:text-sm font-mono text-neutral-400 uppercase tracking-widest border-l-2 border-white/20 pl-4">
          {data.subtitle}
        </p>
      </header>

      <p class="text-neutral-400 text-sm md:text-base leading-relaxed">
        {data.description}
      </p>

      <!-- Tech Stack -->
      <div class="flex flex-wrap gap-2 pt-2">
        {data.stack.map(tech => (
          <span class="px-3 py-1 bg-white/[0.03] border border-white/5 text-neutral-300 text-[11px] font-mono tracking-wider transition-colors hover:bg-white/10 hover:text-white">
            {tech}
          </span>
        ))}
      </div>

      <!-- Links & Actions -->
      <div class="flex flex-wrap items-center gap-4 pt-6 border-t border-white/5 mt-2">
        {data.links?.live && (
          <a
            href={data.links.live}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.3em] font-bold text-white bg-white/10 px-6 py-2 hover:bg-white/20 transition-all duration-300"
          >
            Ver sitio
            <ExternalLink size={14} class="opacity-50" />
          </a>
        )}

        {hasScreenshots && (
          <button
            class={`screenshots-btn inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.3em] font-bold border px-4 py-2 transition-all duration-300 ${
              isAmber
                ? 'text-amber-400 border-amber-400/30 hover:bg-amber-400/10'
                : 'text-blue-400 border-blue-400/30 hover:bg-blue-400/10'
            }`}
            data-modal={id}
          >
            Ver capturas
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
            </svg>
          </button>
        )}

        {data.links?.repo && (
          <a
            href={data.links.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.3em] font-bold text-neutral-400 border border-neutral-800 px-4 py-2 hover:text-white hover:border-neutral-600 transition-all duration-300"
          >
            {data.links.repoBack ? 'Front' : 'Código'}
            <Github size={14} class="opacity-50 group-hover:opacity-100 transition-opacity" />
          </a>
        )}

        {data.links?.repoBack && (
          <a
            href={data.links.repoBack}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.3em] font-bold text-neutral-400 border border-neutral-800 px-4 py-2 hover:text-white hover:border-neutral-600 transition-all duration-300"
          >
            Back
            <Database size={14} class="opacity-50 group-hover:opacity-100 transition-opacity" />
          </a>
        )}
      </div>

    </div>
  </div>
</article>
