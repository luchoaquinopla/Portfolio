---
// src/components/minimal/AcademicProgress.astro
// Sección dedicada para mostrar el progreso en la carrera universitaria
---

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        
        // Disparar las animaciones de las barras segmentadas al hacerse visible
        const segments = entry.target.querySelectorAll('.bar-segment');
        segments.forEach(seg => {
          (seg as HTMLElement).classList.remove('opacity-0');
          (seg as HTMLElement).classList.add('opacity-100');
        });
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.animate-progress').forEach(el => observer.observe(el));
</script>

<style>
  .animate-progress {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes loadProgress {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
</style>

<section id="academic" class="snap-section bg-[#0A0A0A] flex items-center border-t border-white/5">
  <div class="flex flex-col md:grid md:grid-cols-12 md:gap-8 w-full px-6 md:px-0">
    
    <!-- Título de Sección -->
    <div class="md:col-start-2 md:col-end-4 mb-8 md:mb-0 animate-progress">
      <span class="text-[10px] font-mono text-neutral-600 uppercase tracking-[0.5em]">02.5 // Universidad</span>
      <h2 class="text-3xl md:text-5xl font-light text-white tracking-tighter mt-4 ml-[-2px]">
        Carrera<span class="text-neutral-600">.</span>
      </h2>
    </div>

    <!-- Contenido y Barra -->
    <div class="md:col-start-4 md:col-end-10 z-10 w-full animate-progress" style="transition-delay: 0.2s">
      
      <div class="max-w-3xl border border-white/10 bg-white/[0.015] p-8 md:p-12 relative overflow-hidden group">
        <!-- Background accent sutil -->
        <div class="absolute top-0 right-0 w-48 h-48 bg-white/5 blur-[50px] rounded-full -translate-y-1/2 translate-x-1/2 group-hover:bg-white/10 transition-colors duration-700"></div>
        
        <!-- Header del componente -->
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4 relative z-10">
          <div>
            <h3 class="text-base md:text-xl font-light text-white tracking-tight mb-2">Ingeniería en Sistemas de Información</h3>
            <span class="text-[10px] md:text-xs uppercase tracking-[0.3em] font-mono text-neutral-500">UNIVERSIDAD DE LA CUENCA DEL PLATA</span>
          </div>
          <div class="text-left md:text-right">
            <span class="text-[10px] uppercase tracking-[0.3em] font-mono text-neutral-400 border border-white/10 px-3 py-1.5 bg-white/5 rounded-sm">CURSANDO</span>
          </div>
        </div>

        <!-- Progress Bar Segmentada y Responsiva -->
        <div class="w-full mb-6 relative z-10">
          <!-- Labels top -->
          <div class="flex justify-between w-full mb-3 text-[9px] font-mono text-neutral-500">
            <span>INICIO</span>
            <span>META</span>
          </div>
          
          <!-- Contenedor de la barra segmentada (45 materias en total, agrupamos visualmente en 45 bloques en desktop, menos en mobile) -->
          <div class="flex gap-1 md:gap-[2px] h-3 w-full">
            {Array.from({ length: 45 }).map((_, i) => (
              <div 
                class={`flex-1 rounded-[1px] transform origin-left opacity-0 transition-opacity duration-300 ${(i < 36) ? 'bg-white/80' : 'bg-white/10'} bar-segment`}
                style={`transition-delay: ${i * 30}ms`}
              ></div>
            ))}
          </div>
        </div>

        <!-- Metrics Footer -->
        <div class="flex items-center justify-between font-mono text-[10px] sm:text-xs relative z-10 mt-6 pt-6 border-t border-white/5">
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 bg-white rounded-full animate-pulse shadow-[0_0_8px_rgba(255,255,255,0.8)]"></div>
            <span class="text-white font-bold tracking-widest">80% COMPLETADO</span>
          </div>
          <div class="text-neutral-500 tracking-widest">
            <span class="text-neutral-100 font-bold">9</span> RESTANTES
          </div>
        </div>
      </div>
      
    </div>

  </div>
</section>
