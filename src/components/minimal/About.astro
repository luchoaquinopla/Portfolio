---
import { 
  ArrowRight,
  Code2, 
  TerminalSquare, 
  Layout, 
  Layers, 
  Database as DbIcon, 
  Paintbrush,
  Github,
  GitBranch,
  Terminal,
  FileJson
} from '@lucide/astro';

import { getCollection } from 'astro:content';

const allSkills = await getCollection('skills');

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const skillsOrder = [
  'JavaScript', 'TypeScript', 'React', 'Next.js', 'NestJS', 
  'PostgreSQL', 'Tailwind CSS', 'Git', 'GitHub', 'HTML/CSS'
];

const skills = allSkills
  .map(s => s.data)
  .sort((a, b) => skillsOrder.indexOf(a.name) - skillsOrder.indexOf(b.name));
---

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>

<style>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .delay-1 { transition-delay: 0.2s; }
  .delay-2 { transition-delay: 0.4s; }
  .delay-3 { transition-delay: 0.6s; }

  .skill-card:hover {
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 0 20px -5px var(--skill-color);
  }
</style>

<section id="about" class="snap-section bg-[#0A0A0A] flex items-center">
  <div class="flex flex-col md:grid md:grid-cols-12 md:gap-8 w-full px-6 md:px-0">
    
    <!-- Título de Sección -->
    <div class="md:col-start-2 md:col-end-4 mb-8 md:mb-0 animate-on-scroll">
      <span class="text-[10px] font-mono text-neutral-600 uppercase tracking-[0.5em]">02 // Perfil</span>
      <h2 class="text-3xl md:text-5xl font-light text-white tracking-tighter mt-4 ml-[-2px]">
        Sobre mí<span class="text-neutral-600">.</span>
      </h2>
    </div>

    <!-- Bio Principal (Grid Roto en Desktop) -->
    <div class="md:col-start-4 md:col-end-9 z-10">
      <div class="max-w-2xl animate-on-scroll delay-1">
        <p class="text-base md:text-xl text-neutral-300 leading-relaxed font-light">
          A mis 23 años, lo que más disfruto es el proceso de crear software. Me apasiona diseñar soluciones que sean técnicamente sólidas y, a la vez, simples para el usuario. Me gusta enfrentar desafíos que me obliguen a pensar de forma analítica y usar mi formación académica para construir herramientas de calidad.
        </p>

        <!-- Social Action Links -->
        <div class="mt-10 flex flex-col lg:flex-row flex-wrap gap-4">
          <a href="https://github.com/luchoaquinopla" target="_blank" rel="noopener noreferrer" class="text-[10px] uppercase tracking-[0.3em] font-mono text-neutral-400 hover:text-white transition-colors duration-300 border border-white/10 hover:border-white/40 px-6 py-4 flex items-center justify-center gap-3 whitespace-nowrap bg-white/[0.02]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A4.8 4.8 0 0 0 8 18v4"></path><path d="M12 18v4"></path><path d="M12 14h.01"></path></svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/luciano-aquino-?utm_source=share_via&utm_content=profile&utm_medium=member_ios" target="_blank" rel="noopener noreferrer" class="text-[10px] uppercase tracking-[0.3em] font-mono text-neutral-400 hover:text-white transition-colors duration-300 border border-white/10 hover:border-white/40 px-6 py-4 flex items-center justify-center gap-3 whitespace-nowrap bg-white/[0.02]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            LinkedIn
          </a>
          <a href={`${base}/cv/cv-aquino-luciano.pdf`} target="_blank" rel="noopener noreferrer" class="text-[10px] uppercase tracking-[0.3em] font-mono text-black bg-white hover:bg-neutral-200 transition-colors duration-300 px-6 py-4 flex items-center justify-center gap-3 whitespace-nowrap font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
            Ver CV
          </a>
        </div>
      </div>

      <!-- Tech Stack Grid -->
      <div class="mt-16 md:mt-24 animate-on-scroll delay-2">
        <h4 class="text-[10px] uppercase tracking-[0.4em] font-bold text-neutral-500 mb-8 text-center md:text-left">Tecnologías // Stack</h4>
        <div class="grid grid-cols-2 md:grid-cols-[repeat(auto-fit,minmax(130px,1fr))] gap-3">
          {skills.map((skill) => (
            <div 
              class="skill-card group relative flex items-center justify-center p-3 sm:p-4 border border-white/5 bg-white/[0.02] transition-all duration-500 overflow-hidden"
              style={`--skill-color: ${skill.color}`}
            >
              <!-- Glow Effect -->
              <div class="absolute inset-0 bg-[var(--skill-color)] opacity-0 group-hover:opacity-10 transition-opacity duration-500 blur-xl"></div>
              
              <div class="relative z-10 flex flex-row items-center justify-center gap-2 sm:gap-3 w-full">
                <div class="w-4 h-4 sm:w-5 sm:h-5 flex-shrink-0 text-neutral-400 group-hover:text-[var(--skill-color)] transition-colors duration-500 flex items-center justify-center">
                  <svg viewBox="0 0 24 24" class="w-full h-full" fill="currentColor" set:html={skill.svg} />
                </div>
                <span class="text-[10px] sm:text-[11px] uppercase tracking-[0.2em] sm:tracking-widest text-neutral-300 group-hover:text-white transition-colors duration-500 leading-none mt-0.5 truncate text-center">
                  {skill.name}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Decoración Lateral (Solo Desktop) -->
    <div class="hidden md:flex md:col-start-10 md:col-end-12 flex-col justify-end pb-12 opacity-10">
      <div class="h-40 w-px bg-white mb-4"></div>
      <span class="text-[10px] font-mono [writing-mode:vertical-lr] uppercase tracking-[1em] text-white">
        Engineering Excellence
      </span>
    </div>

  </div>
</section>
