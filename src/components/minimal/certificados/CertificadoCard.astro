---
import type { CollectionEntry } from 'astro:content';

interface Props {
  certificado: CollectionEntry<'certificados'>;
  index: number;
}

const { certificado, index } = Astro.props;
const { name, issuer, status, fileUrl, date } = certificado.data;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const isCompleted = status === 'completado';
const numberString = (index + 1).toString().padStart(2, '0');

// Dynamic component wrapper based on status
const Element = isCompleted ? 'a' : 'div';
const htmlProps = isCompleted ? {
  href: `${base}${fileUrl}`,
  target: "_blank",
  rel: "noopener noreferrer"
} : {};
---

<Element 
  {...htmlProps}
  class={`group relative flex flex-col md:flex-row md:items-center justify-between py-8 md:py-12 px-6 rounded-2xl border border-transparent transition-all duration-500 block w-full ${isCompleted ? 'hover:bg-white/[0.03] hover:border-white/10 cursor-pointer' : 'opacity-60'}`}
>
  <!-- Left: Number & Issuer -->
  <div class="flex items-center gap-8 md:w-1/4 mb-4 md:mb-0 relative z-10">
    <span class={`text-xs font-mono text-neutral-600 transition-colors duration-500 ${isCompleted ? 'group-hover:text-neutral-400' : ''}`}>
      Nº{numberString}
    </span>
    <span class={`text-[10px] sm:text-xs tracking-[0.2em] uppercase font-bold text-neutral-400 transition-colors duration-500 ${isCompleted ? 'group-hover:text-neutral-200' : ''}`}>
      {issuer}
    </span>
  </div>

  <!-- Middle: Huge Title -->
  <div class="md:w-1/2 relative z-10 w-full pr-4">
    <h3 class={`text-2xl sm:text-4xl md:text-5xl font-light tracking-tight text-white transition-colors duration-500 mb-2 leading-none ${isCompleted ? 'group-hover:text-white/90' : ''}`}>
      {name}
    </h3>
    {!isCompleted && (
      <div class="inline-flex items-center gap-2 mt-2">
        <span class="w-1.5 h-1.5 bg-neutral-400 rounded-full animate-pulse shadow-[0_0_8px_rgba(163,163,163,0.6)]"></span>
        <span class="text-[10px] uppercase tracking-[0.2em] font-mono text-neutral-400 font-black tracking-widest">En Progreso</span>
      </div>
    )}
  </div>

  <!-- Right: Date & Arrow -->
  <div class="flex items-center justify-between md:justify-end gap-12 mt-6 md:mt-0 md:w-1/4 relative z-10">
    <span class={`font-mono text-neutral-600 transition-colors duration-500 ${isCompleted ? 'group-hover:text-neutral-400' : ''}`}>
      {date || '----'}
    </span>
    {isCompleted ? (
      <div class="w-12 h-12 rounded-full border border-white/10 group-hover:border-white/30 flex items-center justify-center -rotate-45 group-hover:rotate-0 transition-all duration-700 ease-[cubic-bezier(0.19,1,0.22,1)] group-hover:bg-white/5 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </div>
    ) : (
      <div class="w-12 h-12 flex items-center justify-center text-neutral-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lock"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
    )}
  </div>
</Element>
