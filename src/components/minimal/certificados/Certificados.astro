---
import { getCollection } from 'astro:content';
import CertificadoCard from './CertificadoCard.astro';

const allCertificados = await getCollection('certificados');

const completados = allCertificados.filter(c => c.data.status === 'completado').sort((a, b) => {
  if (a.data.date && b.data.date) {
    return parseInt(b.data.date) - parseInt(a.data.date);
  }
  return 0;
});
const enProgreso = allCertificados.filter(c => c.data.status === 'en-progreso');
---

<section id="courses" class="snap-section bg-[#0A0A0A] flex items-start md:items-center py-20 md:py-0 w-full overflow-hidden">
  <div class="flex flex-col w-full px-6 md:px-0 max-w-[1400px] mx-auto">
    
    <!-- Encabezado de sección tipo standard -->
    <div class="md:grid md:grid-cols-12 md:gap-8 mb-16 md:mb-24">
      <div class="md:col-start-2 md:col-end-5 group">
        <span class="text-[10px] font-mono text-neutral-600 uppercase tracking-[0.5em]">04 // Formación</span>
        <h2 class="text-3xl md:text-5xl font-light text-white tracking-tighter mt-4 ml-[-2px]">
          Formación<span class="text-neutral-600">.</span>
        </h2>
      </div>
      <div class="md:col-start-5 md:col-end-11 md:pt-10 mt-6 md:mt-0">
        <p class="text-neutral-400 text-sm md:text-base leading-relaxed font-light">
          Evolución constante. Mantenerse actualizado no es opcional, es el estándar. Aquí documento las capacitaciones continuas que elevan mi criterio arquitectónico y habilidades técnicas.
        </p>
      </div>
    </div>

    <!-- The Index List -->
    <div class="flex flex-col gap-16 md:gap-24 w-full md:pl-[8.333333%]">
      
      <!-- Completados FIRST -->
      <div class="w-full">
        <h3 class="text-neutral-500 font-mono text-[10px] tracking-[0.4em] uppercase mb-8 border-b border-white/10 pb-4">
          [ Archivo Histórico ]
        </h3>
        <div class="flex flex-col w-full">
          {completados.map((cert, index) => <CertificadoCard certificado={cert} index={index} />)}
        </div>
      </div>

      <!-- En progreso SECOND -->
      {enProgreso.length > 0 && (
        <div class="w-full mt-8">
          <h3 class="text-neutral-500 font-mono text-[10px] tracking-[0.4em] uppercase mb-8 border-b border-white/10 pb-4">
            [ Fase Actual ]
          </h3>
          <div class="flex flex-col w-full">
            {enProgreso.map((cert, index) => <CertificadoCard certificado={cert} index={index + completados.length} />)}
          </div>
        </div>
      )}

    </div>
  </div>
</section>
