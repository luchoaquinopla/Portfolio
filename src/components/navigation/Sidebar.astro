---
import { Home, User, FolderCode, GraduationCap, Mail } from '@lucide/astro';

const navItems = [
  { href: '#hero', icon: Home, label: 'Inicio', code: '01' },
  { href: '#about', icon: User, label: 'Perfil', code: '02' },
  { href: '#projects', icon: FolderCode, label: 'Proyectos', code: '03' },
  { href: '#courses', icon: GraduationCap, label: 'Formación', code: '04' },
  { href: '#contact', icon: Mail, label: 'Contacto', code: '05' },
];
---

<!-- Transition Overlay -->
<div id="page-transition" class="fixed inset-0 z-[200] bg-[#0A0A0A] opacity-0 pointer-events-none transition-opacity duration-500"></div>

<!-- Sidebar Desktop: Technical Rail -->
<nav class="hidden md:flex fixed left-0 top-0 h-full w-20 md:w-24 z-[100] flex-col items-center justify-center bg-black/40 backdrop-blur-xl border-r border-white/5">
  <div class="absolute top-12 flex flex-col items-center gap-2">
    <div class="text-xl font-bold tracking-tighter text-white">LA.</div>
    <div class="w-4 h-[1px] bg-white/40"></div>
  </div>
  
  <ul class="flex flex-col gap-8">
    {navItems.map(({ href, icon: Icon, label, code }) => (
      <li class="group relative flex items-center justify-center">
        <a
          href={href}
          data-nav-link
          data-section={href.replace('#', '')}
          class="nav-link relative flex flex-col items-center justify-center w-14 h-14 rounded-lg bg-white/0 hover:bg-white/[0.03] border border-transparent hover:border-white/10 transition-all duration-500 overflow-hidden"
          aria-label={label}
        >
          <!-- Active indicator line -->
          <span class="nav-indicator absolute left-0 top-1/2 -translate-y-1/2 w-[2px] h-0 bg-white rounded-full transition-all duration-500"></span>
          <span class="text-[9px] font-mono text-white/20 group-hover:text-white/60 mb-1 transition-colors nav-code">{code}</span>
          <Icon size={18} stroke-width={1.2} class="nav-icon text-white/30 group-hover:text-white transition-all transform group-hover:scale-110" />
        </a>
        <div class="absolute left-20 pl-4 py-2 border-l border-white/10 opacity-0 group-hover:opacity-100 transition-all translate-x-4 group-hover:translate-x-0 pointer-events-none">
          <p class="text-[10px] uppercase tracking-[0.4em] font-bold text-white whitespace-nowrap">{label}</p>
          <div class="h-px w-10 bg-white/20 mt-1 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></div>
        </div>
      </li>
    ))}
  </ul>

  <div class="absolute bottom-12 flex flex-col items-center gap-4 text-white/10">
    <span class="text-[9px] font-mono [writing-mode:vertical-lr] rotate-180 uppercase tracking-widest">v0.2.0 // 2025</span>
  </div>
</nav>

<!-- Navbar Mobile: Technical Bottom Bar -->
<nav class="flex md:hidden fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-sm h-16 z-[100] items-center justify-around bg-black shadow-[0_0_20px_rgba(0,0,0,0.8)] border border-white/10 rounded-full px-6 backdrop-blur-xl">
  {navItems.map(({ href, icon: Icon, label }) => (
    <a
      href={href}
      data-nav-link
      data-section={href.replace('#', '')}
      class="mobile-nav-link relative flex flex-col items-center justify-center text-white/30 transition-all duration-300 p-2"
      aria-label={label}
    >
      <Icon size={20} stroke-width={1.5} class="mobile-nav-icon" />
      <!-- Active dot indicator -->
      <span class="mobile-nav-dot absolute -bottom-1 w-1 h-1 rounded-full bg-white opacity-0 transition-opacity duration-300 scale-0"></span>
    </a>
  ))}
</nav>

<style>
  /* Active state for desktop */
  .nav-link.is-active .nav-indicator {
    height: 70%;
  }
  .nav-link.is-active .nav-icon {
    color: rgba(255, 255, 255, 0.9);
    transform: scale(1.1);
  }
  .nav-link.is-active .nav-code {
    color: rgba(255, 255, 255, 0.6);
  }
  .nav-link.is-active {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
  }

  /* Active state for mobile */
  .mobile-nav-link.is-active {
    color: rgba(255, 255, 255, 0.9);
  }
  .mobile-nav-link.is-active .mobile-nav-dot {
    opacity: 1;
    transform: scale(1);
  }
</style>

<script>
  const sections = ['hero', 'about', 'projects', 'courses', 'contact'];
  const overlay = document.getElementById('page-transition');

  // --- Scroll Spy via IntersectionObserver ---
  function setActive(sectionId) {
    document.querySelectorAll('[data-nav-link]').forEach((link) => {
      const el = link;
      if (el.dataset.section === sectionId) {
        el.classList.add('is-active');
      } else {
        el.classList.remove('is-active');
      }
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    },
    { threshold: 0.4 }
  );

  sections.forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  // --- Click transition ---
  document.querySelectorAll('[data-nav-link]').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = link.getAttribute('href') || '';
      const target = document.querySelector(href);
      if (!target || !overlay) return;

      // Flash the overlay briefly
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-40');

      setTimeout(() => {
        target.scrollIntoView({ behavior: 'smooth' });
        setTimeout(() => {
          overlay.classList.remove('opacity-40');
          overlay.classList.add('opacity-0', 'pointer-events-none');
        }, 300);
      }, 200);
    });
  });

  // Set initial active based on location hash or default to hero
  const initialHash = window.location.hash.replace('#', '') || 'hero';
  setActive(initialHash);
</script>
